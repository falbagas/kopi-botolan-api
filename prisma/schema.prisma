generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  MANAJER
  KOPERASI
}

enum StatusPengiriman {
  PROSES
  TERKIRIM
  RETUR
}

model User {
  id            String   @id @default(uuid())
  name          String
  email         String   @unique
  passwordHash  String   @map("password_hash")
  role          Role     @default(KOPERASI)
  isActive      Boolean  @default(true) @map("is_active")
  koperasiId    String?  @map("koperasi_id")
  createdAt     DateTime @default(now()) @map("created_at")

  koperasi        Koperasi?        @relation(fields: [koperasiId], references: [id])
  produksiBatch   ProduksiBatch[]
  pengiriman      Pengiriman[]
  penjualan       Penjualan[]
  hppHistory      HppHistory[]
  pembayaran      Pembayaran[]
  transaksi       Transaksi[]
  produksi        Produksi[]
  resepHpp        ResepHpp[]
  mutasiFreezer   MutasiFreezer[]

  @@map("users")
}

model Koperasi {
  id            String   @id @default(uuid())
  name          String
  address       String?
  contactPerson String?  @map("contact_person")
  phone         String?
  minStockAlert Int      @default(20) @map("min_stock_alert")
  hargaJualBotol Decimal @default(0) @map("harga_jual_botol")
  potonganPersen Decimal @default(10) @map("potongan_persen")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")

  users         User[]
  pengiriman    Pengiriman[]
  stokKoperasi  StokKoperasi[]
  penjualan     Penjualan[]
  hargaJual     HargaJual[]
  pembayaran    Pembayaran[]

  @@map("koperasi")
}

model HppHistory {
  id             String   @id @default(uuid())
  biayaBahan     Decimal  @map("biaya_bahan")
  biayaProduksi  Decimal  @map("biaya_produksi")
  biayaLain      Decimal  @default(0) @map("biaya_lain")
  totalHpp       Decimal  @map("total_hpp")
  berlakuDari    DateTime @map("berlaku_dari")
  keterangan     String?
  createdById    String   @map("created_by")
  createdAt      DateTime @default(now()) @map("created_at")

  createdBy       User            @relation(fields: [createdById], references: [id])
  produksiBatch   ProduksiBatch[]
  penjualan       Penjualan[]

  @@map("hpp_history")
}

model HargaJual {
  id          String   @id @default(uuid())
  harga       Decimal
  berlakuDari DateTime @map("berlaku_dari")
  koperasiId  String?  @map("koperasi_id")
  keterangan  String?
  createdAt   DateTime @default(now()) @map("created_at")

  koperasi  Koperasi?   @relation(fields: [koperasiId], references: [id])
  penjualan Penjualan[]

  @@map("harga_jual")
}

model ProduksiBatch {
  id              String   @id @default(uuid())
  batchCode       String   @unique @map("batch_code")
  tanggalProduksi DateTime @map("tanggal_produksi")
  expiredDate     DateTime @map("expired_date")
  jumlahBotol     Int      @map("jumlah_botol")
  catatan         String?
  hppId           String   @map("hpp_id")
  createdById     String   @map("created_by")
  createdAt       DateTime @default(now()) @map("created_at")

  hpp          HppHistory     @relation(fields: [hppId], references: [id])
  createdBy    User           @relation(fields: [createdById], references: [id])
  stokFreezer  StokFreezer?
  pengiriman   Pengiriman[]
  stokKoperasi StokKoperasi[]
  penjualan    Penjualan[]

  @@map("produksi_batch")
}

model StokFreezer {
  id           String   @id @default(uuid())
  batchId      String   @unique @map("batch_id")
  jumlahMasuk  Int      @map("jumlah_masuk")
  jumlahKeluar Int      @default(0) @map("jumlah_keluar")
  stokAkhir    Int      @map("stok_akhir")
  updatedAt    DateTime @updatedAt @map("updated_at")

  batch ProduksiBatch @relation(fields: [batchId], references: [id])

  @@map("stok_freezer")
}

model Pengiriman {
  id           String           @id @default(uuid())
  batchId      String?          @map("batch_id")
  koperasiId   String           @map("koperasi_id")
  jumlahBotol  Int              @map("jumlah_botol")
  tanggalKirim DateTime         @map("tanggal_kirim")
  status       StatusPengiriman @default(PROSES)
  catatan      String?
  dikirimOlehId String          @map("dikirim_oleh")
  createdAt    DateTime         @default(now()) @map("created_at")

  batch        ProduksiBatch?  @relation(fields: [batchId], references: [id])
  koperasi     Koperasi       @relation(fields: [koperasiId], references: [id])
  dikirimOleh  User           @relation(fields: [dikirimOlehId], references: [id])
  stokKoperasi StokKoperasi[]
  detail  PengirimanDetail[]

  @@map("pengiriman")
}

model StokKoperasi {
  id           String   @id @default(uuid())
  koperasiId   String   @map("koperasi_id")
  batchId      String   @map("batch_id")
  pengirimanId String?  @map("pengiriman_id")
  stokMasuk    Int      @default(0) @map("stok_masuk")
  stokTerjual  Int      @default(0) @map("stok_terjual")
  stokRetur    Int      @default(0) @map("stok_retur")
  stokAkhir    Int      @map("stok_akhir")
  updatedAt    DateTime @updatedAt @map("updated_at")

  koperasi   Koperasi      @relation(fields: [koperasiId], references: [id])
  batch      ProduksiBatch @relation(fields: [batchId], references: [id])
  pengiriman Pengiriman?   @relation(fields: [pengirimanId], references: [id])

  @@map("stok_koperasi")
}

model Penjualan {
  id              String   @id @default(uuid())
  koperasiId      String   @map("koperasi_id")
  batchId         String   @map("batch_id")
  hppId           String   @map("hpp_id")
  hargaJualId     String   @map("harga_jual_id")
  jumlahTerjual   Int      @map("jumlah_terjual")
  totalPendapatan Decimal  @map("total_pendapatan")
  totalHpp        Decimal  @map("total_hpp")
  labaKotor       Decimal  @map("laba_kotor")
  tanggalJual     DateTime @map("tanggal_jual")
  dicatatOlehId   String   @map("dicatat_oleh")
  createdAt       DateTime @default(now()) @map("created_at")

  koperasi    Koperasi   @relation(fields: [koperasiId], references: [id])
  batch       ProduksiBatch @relation(fields: [batchId], references: [id])
  hpp         HppHistory @relation(fields: [hppId], references: [id])
  hargaJual   HargaJual  @relation(fields: [hargaJualId], references: [id])
  dicatatOleh User       @relation(fields: [dicatatOlehId], references: [id])

  @@map("penjualan")
}

model JenisKopi {
  id        String   @id @default(uuid())
  nama      String   @unique
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  pengirimanDetail PengirimanDetail[]

  @@map("jenis_kopi")
}

model PengirimanDetail {
  id           String   @id @default(uuid())
  pengirimanId String   @map("pengiriman_id")
  jenisKopiId  String   @map("jenis_kopi_id")
  jumlahBotol  Int      @map("jumlah_botol")
  keterangan   String?
  createdAt    DateTime @default(now()) @map("created_at")

  pengiriman Pengiriman @relation(fields: [pengirimanId], references: [id], onDelete: Cascade)
  jenisKopi  JenisKopi  @relation(fields: [jenisKopiId], references: [id])

  @@map("pengiriman_detail")
}

model Pembayaran {
  id            String   @id @default(uuid())
  koperasiId    String   @map("koperasi_id")
  jumlahBotol   Int      @map("jumlah_botol")
  tanggalBayar  DateTime @map("tanggal_bayar")
  keterangan    String?
  dicatatOlehId String   @map("dicatat_oleh")
  createdAt     DateTime @default(now()) @map("created_at")

  koperasi    Koperasi @relation(fields: [koperasiId], references: [id])
  dicatatOleh User     @relation(fields: [dicatatOlehId], references: [id])

  @@map("pembayaran")
  }

  enum KategoriMenu {
  MAKANAN
  MINUMAN
}

enum MetodeBayar {
  CASH
  QRIS
}

model Menu {
  id        String        @id @default(uuid())
  nama      String
  harga     Decimal
  kategori  KategoriMenu
  isActive  Boolean       @default(true) @map("is_active")
  createdAt DateTime      @default(now()) @map("created_at")

  transaksiDetail TransaksiDetail[]

  @@map("menu")
}

model Transaksi {
  id           String      @id @default(uuid())
  tanggal      DateTime    @default(now())
  metodeBayar  MetodeBayar @map("metode_bayar")
  totalHarga   Decimal     @map("total_harga")
  namaPembeli  String?     @map("nama_pembeli")
  createdById  String      @map("created_by")
  createdAt    DateTime    @default(now()) @map("created_at")

  createdBy User              @relation(fields: [createdById], references: [id])
  detail    TransaksiDetail[]

  @@map("transaksi")
}

model TransaksiDetail {
  id          String  @id @default(uuid())
  transaksiId String  @map("transaksi_id")
  menuId      String  @map("menu_id")
  jumlah      Int
  hargaSatuan Decimal @map("harga_satuan")
  subtotal    Decimal

  transaksi Transaksi @relation(fields: [transaksiId], references: [id], onDelete: Cascade)
  menu      Menu      @relation(fields: [menuId], references: [id])

  @@map("transaksi_detail")
}

model BahanBaku {
  id        String   @id @default(uuid())
  nama      String   @unique
  satuan    String
  stokAwal  Decimal  @default(0) @map("stok_awal")
  stokSaat  Decimal  @default(0) @map("stok_saat_ini")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  produksiDetail ProduksiDetail[]

  @@map("bahan_baku")
}

model RasaKopi {
  id        String   @id @default(uuid())
  nama      String   @unique
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  produksiBotolan ProduksiBotolan[]
  resepHpp        ResepHpp[]
  stokFreezer     StokFreezerV2[]
  mutasi          MutasiFreezer[]

  @@map("rasa_kopi")
}

model Produksi {
  id              String   @id @default(uuid())
  tanggalProduksi DateTime @map("tanggal_produksi")
  jamMulai        DateTime @map("jam_mulai")
  jamSelesai      DateTime @map("jam_selesai")
  durasiJam       Int      @default(0) @map("durasi_jam")
  durasiMenit     Int      @default(0) @map("durasi_menit")
  catatan         String?
  createdById     String   @map("created_by")
  createdAt       DateTime @default(now()) @map("created_at")

  createdBy       User              @relation(fields: [createdById], references: [id])
  botolan         ProduksiBotolan[]
  bahanTerpakai   ProduksiDetail[]

  @@map("produksi")
}

model ProduksiBotolan {
  id          String   @id @default(uuid())
  produksiId  String   @map("produksi_id")
  rasaKopiId  String   @map("rasa_kopi_id")
  jumlahBotol Int      @map("jumlah_botol")
  createdAt   DateTime @default(now()) @map("created_at")

  produksi  Produksi @relation(fields: [produksiId], references: [id], onDelete: Cascade)
  rasaKopi  RasaKopi @relation(fields: [rasaKopiId], references: [id])

  @@map("produksi_botolan")
}

model ProduksiDetail {
  id           String  @id @default(uuid())
  produksiId   String  @map("produksi_id")
  bahanBakuId  String  @map("bahan_baku_id")
  jumlahPakai  Decimal @map("jumlah_pakai")
  createdAt    DateTime @default(now()) @map("created_at")

  produksi   Produksi  @relation(fields: [produksiId], references: [id], onDelete: Cascade)
  bahanBaku  BahanBaku @relation(fields: [bahanBakuId], references: [id])

  @@map("produksi_detail")
}

model BahanHpp {
  id           String   @id @default(uuid())
  nama         String   @unique
  satuan       String
  hargaPerUnit Decimal  @map("harga_per_unit")
  beratPerUnit Decimal  @map("berat_per_unit")
  hargaPerGram Decimal  @map("harga_per_gram")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")

  resepDetail ResepHppDetail[]

  @@map("bahan_hpp")
}

model ResepHpp {
  id          String   @id @default(uuid())
  rasaKopiId  String   @map("rasa_kopi_id")
  totalHpp    Decimal  @map("total_hpp")
  isAktif     Boolean  @default(false) @map("is_aktif")
  catatan     String?
  createdById String   @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")

  rasaKopi    RasaKopi       @relation(fields: [rasaKopiId], references: [id])
  createdBy   User           @relation(fields: [createdById], references: [id])
  detail      ResepHppDetail[]

  @@map("resep_hpp")
}

model ResepHppDetail {
  id           String  @id @default(uuid())
  resepId      String  @map("resep_id")
  bahanHppId   String  @map("bahan_hpp_id")
  jumlahPakai  Decimal @map("jumlah_pakai")
  subtotal     Decimal

  resep    ResepHpp @relation(fields: [resepId], references: [id], onDelete: Cascade)
  bahanHpp BahanHpp @relation(fields: [bahanHppId], references: [id])

  @@map("resep_hpp_detail")
}

model Freezer {
  id        String   @id @default(uuid())
  nama      String   @unique
  lokasi    String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  stokFreezer    StokFreezerV2[]
  mutasiFreezer  MutasiFreezer[]
  mutasiDari     MutasiFreezer[] @relation("FreezertDari")

  @@map("freezer")
}

model StokFreezerV2 {
  id          String   @id @default(uuid())
  freezerId   String   @map("freezer_id")
  rasaKopiId  String   @map("rasa_kopi_id")
  jumlah      Int      @default(0)
  updatedAt   DateTime @updatedAt @map("updated_at")

  freezer    Freezer  @relation(fields: [freezerId], references: [id])
  rasaKopi   RasaKopi @relation(fields: [rasaKopiId], references: [id])

  @@unique([freezerId, rasaKopiId])
  @@map("stok_freezer_v2")
}

enum JenisMutasi {
  MASUK_PRODUKSI
  KELUAR_KOPERASI
  PINDAH_KELUAR
  PINDAH_MASUK
}

model MutasiFreezer {
  id           String      @id @default(uuid())
  freezerId    String      @map("freezer_id")
  freezerTujuanId String?  @map("freezer_tujuan_id")
  rasaKopiId   String      @map("rasa_kopi_id")
  jenis        JenisMutasi
  jumlah       Int
  keterangan   String?
  produksiId   String?     @map("produksi_id")
  createdById  String      @map("created_by")
  createdAt    DateTime    @default(now()) @map("created_at")

  freezer        Freezer   @relation(fields: [freezerId], references: [id])
  freezerTujuan  Freezer?  @relation("FreezertDari", fields: [freezerTujuanId], references: [id])
  rasaKopi       RasaKopi  @relation(fields: [rasaKopiId], references: [id])
  createdBy      User      @relation(fields: [createdById], references: [id])

  @@map("mutasi_freezer")
}